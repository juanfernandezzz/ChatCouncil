# Copiar a .env (o .env.local) para desarrollo local.
# Estos valores por defecto ya vienen embebidos como fallback en el
# codigo (ver src/lib/extension-detect.ts), asi que este archivo es
# opcional en dev — pero es obligatorio documentar aca los que uses en
# produccion (Netlify > Site settings > Environment variables) una vez
# que generes tu propia clave de extension (ver docs/DEPLOY.md).

# Debe coincidir con el ID derivado de la `key` en apps/extension/wxt.config.ts
VITE_EXTENSION_ID=bjplhepllcbcpnhnpnpmcecddbjmlpch

# URL donde el usuario descarga el .zip de la extension (release de GitHub, etc.)
VITE_EXTENSION_DOWNLOAD_URL=https://github.com/juanfernandezzz/ChatCouncil/releases
