{
  "name": "chatcouncil",
  "private": true,
  "version": "0.2.0",
  "description": "ChatCouncil - herramienta de investigacion para analizar, comparar y auditar respuestas de multiples LLMs en paralelo (BYOA/BYOK).",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "pnpm --filter @chatcouncil/web dev",
    "dev:ext": "pnpm --filter @chatcouncil/extension dev",
    "build": "pnpm --filter @chatcouncil/web build && pnpm --filter @chatcouncil/extension build",
    "build:web": "pnpm --filter @chatcouncil/web build",
    "build:ext": "pnpm --filter @chatcouncil/extension build",
    "zip:ext": "pnpm --filter @chatcouncil/extension zip",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "guard:keys": "node scripts/guard-key-vault.mjs",
    "guard:judge": "node scripts/guard-judge-anonymity.mjs",
    "guard:sync": "node scripts/guard-sync-purity.mjs",
    "test": "pnpm -r run test",
    "clean": "pnpm -r exec rm -rf dist .wxt node_modules/.cache",
    "harness:fase5": "pnpm --filter @chatcouncil/web exec vite-node src/dev/fase5-harness.ts",
    "harness:fase6": "pnpm --filter @chatcouncil/web exec vite-node src/dev/fase6-harness.ts",
    "test:e2e": "pnpm --filter @chatcouncil/web run test:e2e",
    "release:check": "node scripts/check-release-version.mjs"
  },
  "devDependencies": {
    "typescript": "7.0.2"
  }
}
